generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── USUARIS ──────────────────────────────────────────────────────
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String   // bcrypt hash
  color     String   @default("#6b7280")
  initials  String   @db.VarChar(2)
  role      Role     @default(AUXILIAR)
  guardia   Boolean  @default(false)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guardias       Guardia[]
  vacations      Vacation[]
  requests       Request[]
  assignments    PositionAssignment[] @relation("TitularAssignments")
  subAssignments PositionAssignment[] @relation("SubAssignments")

  // NextAuth
  accounts Account[]
  sessions Session[]

  @@map("users")
}

enum Role {
  ADMIN
  AUXILIAR
}

// ── GUARDIES ─────────────────────────────────────────────────────
model Guardia {
  id        Int      @id @default(autoincrement())
  userId    Int
  satDate   String   // YYYY-MM-DD del dissabte
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([satDate])
  @@map("guardias")
}

// ── VACANCES ─────────────────────────────────────────────────────
model Vacation {
  id        Int           @id @default(autoincrement())
  userId    Int
  dates     String[]      // Array de YYYY-MM-DD (dies laborables)
  status    RequestStatus @default(PENDING)
  comment   String?
  requestId Int?          // vincle amb la sol·licitud que la va originar
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  request Request? @relation(fields: [requestId], references: [id], onDelete: SetNull)

  @@map("vacations")
}

// ── SOL·LICITUDS ─────────────────────────────────────────────────
model Request {
  id        Int           @id @default(autoincrement())
  userId    Int
  type      RequestType
  fromDate  String        // YYYY-MM-DD
  toDate    String?
  comment   String?
  status    RequestStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  vacations Vacation[]

  @@map("requests")
}

enum RequestType {
  GUARDIA      // Sol·licitar nova guàrdia
  VACATION     // Sol·licitar vacances
  REMOVE       // Sol·licitar eliminació de guàrdia
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// ── FESTIUS ──────────────────────────────────────────────────────
model Holiday {
  id   Int    @id @default(autoincrement())
  date String @unique // YYYY-MM-DD
  name String?

  @@map("holidays")
}

// ── POSICIONS ────────────────────────────────────────────────────
model Position {
  id          String @id
  name        String
  shortName   String
  displayOrder Int   @default(0)

  assignments PositionAssignment[]

  @@map("positions")
}

// ── ASSIGNACIÓ DE POSICIONS ───────────────────────────────────────
model PositionAssignment {
  id         Int      @id @default(autoincrement())
  date       String   // YYYY-MM-DD
  positionId String
  userId     Int?     // titular
  subUserId  Int?     // suplent (si el titular no hi és)
  createdAt  DateTime @default(now())

  position Position @relation(fields: [positionId], references: [id])
  user     User?    @relation("TitularAssignments", fields: [userId], references: [id], onDelete: SetNull)
  subUser  User?    @relation("SubAssignments", fields: [subUserId], references: [id], onDelete: SetNull)

  @@unique([date, positionId])
  @@map("position_assignments")
}

// ── NOTES DE DIA ─────────────────────────────────────────────────
model DayNote {
  id        Int      @id @default(autoincrement())
  date      String   @unique // YYYY-MM-DD
  note      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("day_notes")
}

// ── NEXTAUTH ─────────────────────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       Int
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
