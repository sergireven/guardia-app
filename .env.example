# ── BASE DE DADES (Neon PostgreSQL) ──────────────────────────────
# Obtén-ho a: https://console.neon.tech → New Project → Connection string
DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# ── AUTENTICACIÓ (NextAuth) ───────────────────────────────────────
# Genera un secret aleatori: openssl rand -base64 32
AUTH_SECRET="canvia-per-un-secret-aleatori-molt-llarg"

# URL base de l'aplicació
NEXTAUTH_URL="http://localhost:3000"
# En producció: NEXTAUTH_URL="https://el-teu-domini.vercel.app"
